{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/test_config.schema.json",
  "title": "TUI K6 Runtime Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["baseURL", "auth", "requestEndpoints", "k6"],
  "properties": {
    "baseURL": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "auth": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "client_id", "client_secret"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "oauth2_client_credentials", "basic", "client_id_enforcement"]
        },
        "client_id": {"type": "string"},
        "client_secret": {"type": "string"},
        "token_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
        "scope": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"mode": {"const": "oauth2_client_credentials"}},
            "required": ["mode"]
          },
          "then": {
            "required": ["client_id", "client_secret", "token_url", "scope"],
            "properties": {
              "client_id": {"minLength": 1},
              "client_secret": {"minLength": 1},
              "token_url": {"minLength": 1},
              "scope": {"minLength": 1}
            }
          }
        },
        {
          "if": {
            "properties": {"mode": {"enum": ["basic", "client_id_enforcement"]}},
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "client_id": {"minLength": 1},
              "client_secret": {"minLength": 1}
            }
          }
        }
      ]
    },
    "requestEndpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "method", "path"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
          },
          "path": {"type": "string", "pattern": "^/"},
          "headers": {"type": ["object", "null"]},
          "body": {},
          "query": {"type": ["object", "null"]}
        }
      }
    },
    "k6": {
      "type": "object",
      "additionalProperties": true,
      "required": ["executionType", "thresholds"],
      "properties": {
        "executionType": {
          "type": "string",
          "enum": [
            "external executor",
            "Spike Tests",
            "Constant VUs",
            "Constant Arrival Rate",
            "Ramping Arrival Rate"
          ]
        },
        "connectionManagement": {
          "type": "string",
          "enum": ["keep-alive", "no connection reuse", "no vu connection reuse"]
        },
        "vus": {"type": "integer", "minimum": 1},
        "maxVUs": {"type": "integer", "minimum": 1},
        "duration": {"type": "string", "pattern": "^\\d+(ms|s|m|h)$"},
        "rate": {"type": "integer", "minimum": 1},
        "timeUnit": {"type": "string", "pattern": "^\\d+(ms|s|m|h)$"},
        "preAllocatedVUs": {"type": "integer", "minimum": 1},
        "startRate": {"type": "integer", "minimum": 1},
        "spikeStages": {"$ref": "#/$defs/stages"},
        "rampingArrivalStages": {"$ref": "#/$defs/stages"},
        "thresholds": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {
                  "type": "object",
                  "required": ["threshold"],
                  "properties": {
                    "threshold": {"type": "string", "minLength": 1},
                    "abortOnFail": {"type": "boolean"},
                    "delayAbortEval": {"type": "string", "pattern": "^\\d+(ms|s|m|h)$"}
                  }
                }
              ]
            }
          }
        },
        "logging": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {"type": "boolean"},
            "level": {"type": "string", "enum": ["all", "failed", "failed_without_payloads"]},
            "outputToUI": {"type": "boolean"},
            "webDashboard": {"type": "boolean"},
            "webDashboardUrl": {"type": "string", "format": "uri", "pattern": "^https?://"},
            "htmlSummaryReport": {"type": "boolean"}
          },
          "allOf": [
            {
              "if": {
                "properties": {"webDashboard": {"const": true}},
                "required": ["webDashboard"]
              },
              "then": {
                "required": ["webDashboardUrl"],
                "properties": {"webDashboardUrl": {"minLength": 1}}
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"executionType": {"const": "external executor"}}, "required": ["executionType"]},
          "then": {"required": ["vus", "duration"]}
        },
        {
          "if": {"properties": {"executionType": {"const": "Spike Tests"}}, "required": ["executionType"]},
          "then": {"required": ["spikeStages"]}
        },
        {
          "if": {"properties": {"executionType": {"const": "Constant VUs"}}, "required": ["executionType"]},
          "then": {"required": ["vus", "duration"]}
        },
        {
          "if": {"properties": {"executionType": {"const": "Constant Arrival Rate"}}, "required": ["executionType"]},
          "then": {"required": ["rate", "timeUnit", "duration", "preAllocatedVUs"]}
        },
        {
          "if": {"properties": {"executionType": {"const": "Ramping Arrival Rate"}}, "required": ["executionType"]},
          "then": {"required": ["startRate", "timeUnit", "preAllocatedVUs", "rampingArrivalStages"]}
        }
      ]
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "required": ["duration", "target"],
      "properties": {
        "duration": {"type": "string", "pattern": "^\\d+(ms|s|m|h)$"},
        "target": {"type": "integer", "minimum": 0}
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/stage"}
    }
  }
}
